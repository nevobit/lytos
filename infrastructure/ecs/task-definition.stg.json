{
  "family": "lytos-api-stg",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "743569699917.dkr.ecr.us-east-1.amazonaws.com/nevobit/lytos-api:stg-latest",
      "memory": 512,
      "cpu": 256,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "staging" },
        { "name": "APP_ENV", "value": "staging" }
      ],
      "linuxParameters": {
        "initProcessEnabled": true,
        "tmpfs": [
          {
            "containerPath": "/tmp",
            "size": 64,
            "mountOptions": ["rw", "nosuid", "noexec", "nodev"]
          }
        ]
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lytos-api-stg",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ],
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "executionRoleArn": "arn:aws:iam::743569699917:role/ecsTaskExecutionRole-lytos-stg",
  "cpu": "256",
  "memory": "512"
}
